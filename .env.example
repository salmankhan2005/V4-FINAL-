# Groq API key — get one at https://console.groq.com/keys
GROQ_API_KEY=gsk_your_api_key_here

# Optional: override the Groq model (defaults to llama-3.1-8b-instant)
# GROQ_MODEL=llama-3.1-8b-instant

# Optional: extra origins allowed to call server functions (comma-separated).
# Only needed if you serve the app from a domain that differs from the
# canonical Vercel deployment URL (e.g. apex + www, or a custom domain).
# CSRF_ALLOWED_ORIGINS=https://v4nexus.com,https://www.v4nexus.com
